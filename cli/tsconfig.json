{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "lib":  [
                                        "ES2022"
                                    ],
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "resolveJsonModule":  true,
                            "declaration":  true,
                            "declarationMap":  true,
                            "sourceMap":  true,
                            "outDir":  "./dist",
                            "jsx":  "react-jsx",
                            "jsxImportSource":  "react",
                            "types":  [
                                          "node"
                                      ],
                            "rootDir":  "./src",
                            "noImplicitAny":  false
                        },
    "include":  [
                    "src/**/*.ts",
                    "src/**/*.tsx"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
